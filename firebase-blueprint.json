{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile metadata, settings and preference details.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user ID matching their authenticated UID." },
        "email": { "type": "string", "format": "email", "description": "User profile registration email address." },
        "displayName": { "type": "string", "description": "Display name selected by user." },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "The visual display theme theme mode." },
        "ttsVoice": { "type": "string", "enum": ["Kore", "Puck", "Charon", "Fenrir", "Zephyr"], "description": "Default Voice-to-Text narration speaker identity." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The moment the user profile record was created sync timestamp." }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "An interactive conversational AI session with context metadata.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "Unique session chat identifier." },
        "userId": { "type": "string", "description": "Owner userId of this chat session." },
        "title": { "type": "string", "description": "Generated or user-set title of the conversation." },
        "category": { "type": "string", "description": "The AI tool class (e.g. translation, content writer, study, general)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Matching UTC timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Active modification moment." }
      },
      "required": ["chatId", "userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single text or system code interaction block inside a chat.",
      "type": "object",
      "properties": {
        "messageId": { "type": "string", "description": "Unique identifier of this statement." },
        "chatId": { "type": "string", "description": "The parent chat session ID." },
        "userId": { "type": "string", "description": "UID of the owner user." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Whether sent by a human or generated by AI." },
        "content": { "type": "string", "description": "Raw visual text or code markup." },
        "type": { "type": "string", "description": "Functional subtype (text, code, translate, summary, etc.)" },
        "voiceNarration": { "type": "string", "description": "Optional base64 audio block if generated." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Specific chat prompt timestamp." }
      },
      "required": ["messageId", "chatId", "userId", "role", "content", "createdAt"]
    },
    "Document": {
      "title": "Knowledge Document",
      "description": "Parsed user text documents, TXT summaries and extracted concepts.",
      "type": "object",
      "properties": {
        "documentId": { "type": "string", "description": "Document tracking ID." },
        "userId": { "type": "string", "description": "The owner of the document tracker." },
        "name": { "type": "string", "description": "Name of the file uploaded." },
        "type": { "type": "string", "description": "File format type extension (PDF, TXT, DOCX)." },
        "content": { "type": "string", "description": "Extract file content parsing." },
        "summary": { "type": "string", "description": "AI compiled structural summary." },
        "keyPoints": { "type": "array", "description": "A computed bullet roster of conclusions." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload sync timestamp." }
      },
      "required": ["documentId", "userId", "name", "content", "createdAt"]
    },
    "Knowledge": {
      "title": "Semantic Knowledge Base",
      "description": "Personal storage items and semantic key points contributing to AI contextual memory.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string", "description": "Item identification." },
        "userId": { "type": "string", "description": "Owner identifier." },
        "title": { "type": "string", "description": "Title context snippet." },
        "body": { "type": "string", "description": "Underlying information." },
        "useAsMemory": { "type": "boolean", "description": "Flag to pass this context to future chat prompts." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Sync entry stamp." }
      },
      "required": ["itemId", "userId", "title", "body", "useAsMemory", "createdAt"]
    },
    "Note": {
      "title": "Personal Notes",
      "description": "Local cached or synchronized markdown sheets.",
      "type": "object",
      "properties": {
        "noteId": { "type": "string", "description": "Note UID tracker." },
        "userId": { "type": "string", "description": "Owner userId." },
        "title": { "type": "string", "description": "Note main title." },
        "content": { "type": "string", "description": "Standard rich editor text body." },
        "folder": { "type": "string", "description": "Note folder categorizing list." },
        "isSynced": { "type": "boolean", "description": "Offline-aware sync check." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Modification date." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["noteId", "userId", "title", "content", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Productivity Task",
      "description": "Dashboard list item or deadline tracking slot.",
      "type": "object",
      "properties": {
        "taskId": { "type": "string", "description": "Task identity handle." },
        "userId": { "type": "string", "description": "Owner account key." },
        "title": { "type": "string", "description": "Task action text." },
        "description": { "type": "string", "description": "Optional descriptions detail." },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "Status state checkbox." },
        "dueDate": { "type": "string", "description": "Calendar deadline trigger." },
        "goalId": { "type": "string", "description": "Linked tracking goal tracker if any." },
        "reminderEnabled": { "type": "boolean", "description": "Toggle alerts on screen." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp." }
      },
      "required": ["taskId", "userId", "title", "status", "createdAt"]
    },
    "Goal": {
      "title": "Development Target",
      "description": "Target goals with progress slider stats.",
      "type": "object",
      "properties": {
        "goalId": { "type": "string", "description": "Goal marker target." },
        "userId": { "type": "string", "description": "Owner account ID." },
        "title": { "type": "string", "description": "Goal designation title." },
        "targetValue": { "type": "number", "description": "Absolute target criteria." },
        "currentValue": { "type": "number", "description": "Existing status progression gauge." },
        "unit": { "type": "string", "description": "Measurement indicator e.g. percent, books, tasks." },
        "deadline": { "type": "string", "description": "Goal objective date limit." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp." }
      },
      "required": ["goalId", "userId", "title", "targetValue", "currentValue", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual profile documents keyed by Auth UID."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "User and model conversation root logs and headers."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Dialogue exchanges relating to the active chat session."
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Users knowledge files and textual digest transcripts."
    },
    "/knowledge/{itemId}": {
      "schema": "Knowledge",
      "description": "Personal elements constituting the persistent cognitive database."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes and offline synchronized items."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Todo checkpoints and productivity reminders."
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Aspiration trackers measuring specific numeric metrics output."
    }
  }
}
